{
  "name": "AI Keeper",
  "version": "0.21.0",
  "local_only": true,
  "metadata_only": true,
  "default_port": 8766,
  "scripts": {
    "install": "scripts/install.sh",
    "package": "scripts/package.sh",
    "publish": "scripts/publish.sh",
    "release": "scripts/release.sh",
    "sign": "scripts/sign-release.sh",
    "upgrade": "scripts/upgrade.sh",
    "rollback": "scripts/rollback.sh"
  },
  "repository": {
    "url": "git@github.com:alevkin/ai-keeper.git",
    "homepage": "https://github.com/alevkin/ai-keeper",
    "visibility": "private"
  },
  "targets": {
    "source_archive": "dist/aikeeper-<version>.tar.gz",
    "homebrew_formula": "dist/homebrew/aikeeper.rb",
    "homebrew_tap_formula": "dist/homebrew-tap/Formula/aikeeper.rb",
    "checksums": "dist/CHECKSUMS.txt",
    "ci_workflow": ".github/workflows/ci.yml",
    "release_notes": "dist/release-notes.md",
    "repo_settings_checklist": "docs/repo-settings-checklist.md",
    "macos_dmg_wrapper": "packaging/macos/dmg/Aikeeper Installer.command",
    "windows_service_prep": "packaging/windows/install-service.ps1"
  },
  "runtime": {
    "language": "Python",
    "package_manager": "uv",
    "service_manager": "launchd"
  },
  "future_targets": [
    "repo-owner-actions",
    "ci-follow-up",
    "release-upload-design",
    "public-launch-copy"
  ]
}
