{
  "name": "AI Keeper",
  "version": "0.25.0",
  "local_only": true,
  "metadata_only": true,
  "default_port": 8766,
  "scripts": {
    "install": "scripts/install.sh",
    "package": "scripts/package.sh",
    "publish": "scripts/publish.sh",
    "publish_homebrew_tap": "scripts/publish-homebrew-tap.sh",
    "public_release_gate": "scripts/public-release-gate.sh",
    "release": "scripts/release.sh",
    "sign": "scripts/sign-release.sh",
    "upgrade": "scripts/upgrade.sh",
    "rollback": "scripts/rollback.sh"
  },
  "repository": {
    "url": "git@github.com:alevkin/ai-keeper.git",
    "homepage": "https://github.com/alevkin/ai-keeper",
    "visibility": "private"
  },
  "targets": {
    "source_archive": "dist/aikeeper-<version>.tar.gz",
    "homebrew_formula": "dist/homebrew/aikeeper.rb",
    "homebrew_tap_formula": "dist/homebrew-tap/Formula/aikeeper.rb",
    "homebrew_tap_publish": "scripts/publish-homebrew-tap.sh",
    "checksums": "dist/CHECKSUMS.txt",
    "ci_workflow": ".github/workflows/ci.yml",
    "release_workflow": ".github/workflows/release.yml",
    "public_release_gate_workflow": ".github/workflows/public-release-gate.yml",
    "release_notes": "dist/release-notes.md",
    "changelog": "CHANGELOG.md",
    "github_ops_status": "docs/github-ops-status.md",
    "public_release_gate_doc": "docs/public-release-gate.md",
    "release_upload_design": "docs/release-upload-design.md",
    "repo_settings_checklist": "docs/repo-settings-checklist.md",
    "version_updater": "scripts/update-version.py",
    "changelog_generator": "scripts/generate-changelog.py",
    "public_release_gate": "scripts/public-release-gate.sh",
    "issue_template_config": ".github/ISSUE_TEMPLATE/config.yml",
    "bug_report_template": ".github/ISSUE_TEMPLATE/bug_report.yml",
    "feature_request_template": ".github/ISSUE_TEMPLATE/feature_request.yml",
    "security_contact_template": ".github/ISSUE_TEMPLATE/security_contact.yml",
    "macos_dmg_wrapper": "packaging/macos/dmg/Aikeeper Installer.command",
    "windows_service_prep": "packaging/windows/install-service.ps1"
  },
  "homebrew_tap": {
    "repository": "alevkin/homebrew-tap",
    "remote": "git@github.com:alevkin/homebrew-tap.git",
    "formula": "Formula/aikeeper.rb",
    "install": "brew install alevkin/tap/aikeeper"
  },
  "runtime": {
    "language": "Python",
    "package_manager": "uv",
    "service_manager": "launchd"
  },
  "signing": {
    "default": "cosign-keyless",
    "issuer": "https://token.actions.githubusercontent.com",
    "identity": "https://github.com/alevkin/ai-keeper/.github/workflows/release.yml@refs/heads/main",
    "bundles": [
      "dist/aikeeper-<version>.tar.gz.sigstore.json",
      "dist/CHECKSUMS.txt.sigstore.json",
      "dist/release-manifest.json.sigstore.json"
    ],
    "optional": [
      "minisign"
    ]
  },
  "future_targets": [
    "public-visibility-switch",
    "brew-install-smoke-test",
    "signed-macos-installer"
  ]
}
